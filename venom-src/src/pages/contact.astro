---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact - Semiautonomous Systems"
  description="Get in touch with Semiautonomous Systems about AI crawler enforcement, defensive data poisoning research, crawler-compliance measurement, and the VENOM product."
  currentPath="/contact/"
>
  <Fragment slot="head">
    <link rel="canonical" href="https://semiautonomous.systems/contact/" />
  </Fragment>

  <section class="section">
    <div class="container" style="max-width: 680px;">
      <h1>Get in touch</h1>
      <p class="contact-intro">
        Questions about AI crawler enforcement, defensive data poisoning,
        crawler-compliance measurement, or the VENOM product? Email us directly.
      </p>

      <p class="contact-email">
        <a href="mailto:venom@semiautonomous.systems">venom@semiautonomous.systems</a>
      </p>

      <p class="contact-note">
        If your browser has no mail client configured, copy the address above and
        write to us from wherever you read mail.
      </p>
      <p class="contact-note">
        Press, research collaboration, and standards work are all welcome. Put the
        topic in your subject line and we will route it to the right person.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-intro {
    font-size: clamp(16px, 2vw, 18px);
    max-width: 600px;
  }
  .contact-email {
    margin: var(--space-xl) 0 var(--space-md);
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 700;
    font-family: var(--font-display);
    word-break: break-word;
  }
  .contact-email a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .contact-email a:hover {
    text-decoration: underline;
  }
  .contact-note {
    color: var(--color-text-muted);
    font-size: 14px;
    margin-top: var(--space-sm);
  }
</style>
